# Google Sheets service account credentials (raw JSON or base64-encoded)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet ID (from the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit)
SPREADSHEET_ID=

# Optional: Resend email digest
RESEND_API_KEY=
DIGEST_EMAIL_TO=
DIGEST_EMAIL_FROM=
